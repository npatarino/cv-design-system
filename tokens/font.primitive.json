        "thunder":   { "$value": "'Thunder', 'Oswald', 'Helvetica Neue', sans-serif",      "$type": "fontFamily", "$description": "Thunder — tall condensed sans for data." },
        "nudicaMono": { "$value": "'Nudica Mono', 'Courier New', monospace",                "$type": "fontFamily", "$description": "Nudica Mono — for labels, eyebrows and code." }
