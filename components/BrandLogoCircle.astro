/*
 * BrandLogoCircle — the seal-style logo: chimi silhouette inside a ring of
 * tiny perimeter text reading "Chimichurri Code · By Nicolás Patarino · 2024".
 *
 * Two colors (matches assets/logos/logo-circle.svg):
 *   - `textColor`: ring text + mate outline (one stamp tint, like CSS `color` + `currentColor`)
 *   - `markColor`: mate bowl / interior fill only
 *
 * Source SVG: packages/design-system/assets/logos/logo-circle.svg.
 */
interface Props {
  size?: number;
  textColor?: string;
  markColor?: string;
  ariaLabel?: string;
}
const {
  size = 256,
  textColor = "#272727",
  markColor = "#02B5B9",
  ariaLabel,
} = Astro.props;
const labelled = !!ariaLabel;
