---
/*
 * BrandLogoWordmark — the "ChimiCode" wordmark with the chimi character on
 * the left. Single-color SVG (currentColor); the surrounding link/element
 * sets the color (defaults to brand teal in most contexts; flips to ivory
 * or charcoal when nested inside a themed container).
 *
 * Source SVG: packages/design-system/assets/logos/logo-code.svg.
 */
interface Props {
  size?: number;
  ariaLabel?: string;
}
const { size = 200, ariaLabel } = Astro.props;
const labelled = !!ariaLabel;
const height = Math.round((size * 107) / 202);
