---
/*
 * BrandMark — the Chimichurri Code character glyph (the silhouette of the
 * chimi/mate). Inlined as SVG so it inherits the surrounding `color` via
 * `fill="currentColor"`, which means it adapts to the active theme:
 *   - dark: ivory on charcoal canvas
 *   - light: charcoal on ivory canvas
 *
 * THE MATE RULE — there is exactly one canonical mate in the system, and it
 * lives here. Anywhere a mate-shaped glyph appears (favicons, eyebrows,
 * watermarks, stickers, social templates), it must come from this component
 * (Astro), `CCLogo.mark()` (vanilla JS), or `logo-character.svg` directly.
 * Drawing a mate inline with ad-hoc `<path>` data is forbidden — the linter
 * won't catch it, but review will. See `docs/recipes.md#brand-assets`.
 *
 * Tip for callers: wrap it in a span/anchor that sets `color` to brand teal
 * (var(--recipe-accent)) if you want it tinted instead of adapting to the
 * carrying recipe.
 *
 * Source SVG lives in `packages/brand/shared/logo-character.svg` (synced
 * from `packages/design-system/assets/logos/`). This component duplicates
 * the paths so it's bundled with the design system and doesn't depend on a
 * runtime fetch from `/brand/`.
 */
interface Props {
  size?: number;
  ariaLabel?: string;
}
const { size = 22, ariaLabel } = Astro.props;
const labelled = !!ariaLabel;
---

<svg
  width={size}
  height={Math.round((size * 82) / 38)}
  viewBox="0 0 38 82"
  fill="currentColor"
  xmlns="http://www.w3.org/2000/svg"
  role={labelled ? "img" : "presentation"}
  aria-label={ariaLabel}
  aria-hidden={labelled ? undefined : "true"}
>
